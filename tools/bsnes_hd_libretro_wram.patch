diff --git a/bsnes/target-libretro/libretro.cpp b/bsnes/target-libretro/libretro.cpp
--- a/bsnes/target-libretro/libretro.cpp
+++ b/bsnes/target-libretro/libretro.cpp
@@
-// Currently, there is no safe/sensible way to use the memory interface without severe hackery.
-// Rely on higan to load and save SRAM until there is really compelling reason not to.
 void *retro_get_memory_data(unsigned id)
 {
+	if ((id & RETRO_MEMORY_MASK) == RETRO_MEMORY_SYSTEM_RAM)
+		return SuperFamicom::cpu.wram;
 	return nullptr;
 }
 
 size_t retro_get_memory_size(unsigned id)
 {
+	if ((id & RETRO_MEMORY_MASK) == RETRO_MEMORY_SYSTEM_RAM)
+		return sizeof(SuperFamicom::cpu.wram);
 	return 0;
 }
